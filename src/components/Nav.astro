---
const currentPath = Astro.url.pathname;

const primaryItems = [
  { label: 'Analysis', href: '/analysis' },
  { label: 'Videos', href: '/videos' },
  { label: 'Market Watch', href: '/market-watch' },
  { label: 'About', href: '/about' },
];

const subnavItems = [
  // Editorial lenses
  { label: 'Unit Economics', href: '/analysis/unit-economics' },
  { label: 'Neighborhood Alpha', href: '/analysis/neighborhood-alpha' },
  { label: 'Market Entry', href: '/analysis/market-entry' },
  { label: 'Supplier Intel', href: '/analysis/supplier-intel' },
  // Coverage
  { label: 'Operator Profiles', href: '/operators' },
  { label: 'M&A & Deals', href: '/deals' },
  // Utility
  { label: 'Data & Charts', href: '/data' },
  { label: 'Tools', href: '/tools' },
];

const today = new Date().toLocaleDateString('en-US', {
  weekday: 'long',
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
---

<header class="masthead">
  <div class="container">
    <div class="masthead-inner">
      <button class="hamburger" aria-label="Open menu">
        <span></span><span></span><span></span>
      </button>

      <div class="masthead-left">
        <span class="masthead-date">{today}</span>
      </div>

      <a href="/" class="masthead-logo" aria-label="SpoonAsia home">
        SpoonAsia
      </a>

      <div class="masthead-right">
        <button class="search-btn" aria-label="Search">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <circle cx="11" cy="11" r="8"/>
            <line x1="21" y1="21" x2="16.65" y2="16.65"/>
          </svg>
        </button>
        <a href="/newsletter" class="newsletter-link">↗ Newsletters</a>
        <span class="masthead-divider" aria-hidden="true"></span>
        <a href="/penguin-x" class="subscribe-btn">Subscribe</a>
      </div>
    </div>
  </div>
</header>

<nav class="primary-nav">
  <div class="container">
    <div class="primary-nav-inner">
      {primaryItems.map((item) => {
        const isActive = currentPath.startsWith(item.href);
        return (
          <a href={item.href} class={`primary-nav-link ${isActive ? 'active' : ''}`}>
            {item.label}
          </a>
        );
      })}
      <a href="/penguin-x" class={`primary-nav-link cta ${currentPath.startsWith('/penguin-x') ? 'active' : ''}`}>
        Penguin X ↗
      </a>
    </div>
  </div>
</nav>

<div class="subnav">
  <div class="container">
    <div class="subnav-inner">
      {subnavItems.map((item) => (
        <a href={item.href} class="subnav-link">{item.label}</a>
      ))}
    </div>
  </div>
</div>

<style>
  .masthead {
    background: var(--paper);
    padding: 20px 0 16px;
    border-bottom: 1px solid var(--hairline);
  }

  .masthead-inner {
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    align-items: center;
    gap: 24px;
  }

  .hamburger {
    display: none;
    flex-direction: column;
    gap: 4px;
    background: transparent;
    border: none;
    cursor: pointer;
    padding: 8px;
  }
  .hamburger span {
    display: block;
    width: 20px;
    height: 2px;
    background: var(--ink);
  }

  .masthead-left {
    display: flex;
    align-items: center;
  }

  .masthead-date {
    font-family: var(--font-sans);
    font-size: 12px;
    color: var(--ink-soft);
    font-weight: 500;
  }

  .masthead-logo {
    font-family: var(--font-sans);
    font-size: 42px;
    font-weight: 800;
    letter-spacing: -0.03em;
    color: var(--ink);
    text-decoration: none;
    border-bottom: none;
    line-height: 1;
    transition: color 0.15s ease;
  }
  .masthead-logo:hover {
    color: var(--accent);
  }

  .masthead-right {
    display: flex;
    justify-content: flex-end;
    align-items: center;
    gap: 12px;
  }

  .search-btn {
    background: transparent;
    border: none;
    cursor: pointer;
    color: var(--ink);
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 8px;
    transition: color 0.15s ease;
  }
  .search-btn:hover { color: var(--accent); }

  .newsletter-link {
    font-family: var(--font-sans);
    font-size: 13px;
    font-weight: 600;
    color: var(--accent);
    text-decoration: none;
    border-bottom: none;
    letter-spacing: 0.005em;
    white-space: nowrap;
    transition: color 0.15s ease;
  }
  .newsletter-link:hover { color: var(--accent-deep); }

  .masthead-divider {
    display: inline-block;
    width: 1px;
    height: 16px;
    background: var(--hairline-strong);
    flex-shrink: 0;
  }

  .subscribe-btn {
    display: inline-block;
    background: var(--ink);
    color: var(--paper);
    font-family: var(--font-sans);
    font-size: 13px;
    font-weight: 600;
    padding: 9px 18px;
    text-decoration: none;
    border: none;
    border-bottom: none;
    border-radius: 2px;
    transition: background 0.15s ease;
    letter-spacing: 0.01em;
  }
  .subscribe-btn:hover {
    background: var(--accent);
    color: var(--paper);
  }

  .primary-nav {
    background: var(--paper);
    border-bottom: 1px solid var(--ink);
  }

  .primary-nav-inner {
    display: flex;
    gap: 0;
    align-items: center;
    overflow-x: auto;
    scrollbar-width: none;
  }
  .primary-nav-inner::-webkit-scrollbar { display: none; }

  .primary-nav-link {
    font-family: var(--font-sans);
    font-size: 14px;
    font-weight: 600;
    color: var(--ink);
    text-decoration: none;
    border-bottom: none;
    padding: 14px 18px;
    white-space: nowrap;
    letter-spacing: -0.005em;
    position: relative;
    transition: color 0.15s ease;
  }
  .primary-nav-link:first-child { padding-left: 0; }
  .primary-nav-link:hover { color: var(--accent); }
  .primary-nav-link.active::after {
    content: '';
    position: absolute;
    bottom: -1px;
    left: 18px;
    right: 18px;
    height: 3px;
    background: var(--accent);
  }
  .primary-nav-link.active:first-child::after { left: 0; }
  .primary-nav-link.cta {
    margin-left: auto;
    color: var(--accent);
  }

  .subnav {
    background: var(--paper);
    border-bottom: 1px solid var(--hairline);
  }

  .subnav-inner {
    display: flex;
    gap: 0;
    overflow-x: auto;
    scrollbar-width: none;
  }
  .subnav-inner::-webkit-scrollbar { display: none; }

  .subnav-link {
    font-family: var(--font-sans);
    font-size: 12px;
    font-weight: 500;
    color: var(--ink-soft);
    text-decoration: none;
    border-bottom: none;
    padding: 10px 14px;
    white-space: nowrap;
    transition: color 0.15s ease;
  }
  .subnav-link:first-child { padding-left: 0; }
  .subnav-link:hover { color: var(--ink); }

  @media (max-width: 768px) {
    .masthead-inner {
      grid-template-columns: auto 1fr auto;
    }
    .hamburger { display: flex; }
    .masthead-left { display: none; }
    .masthead-logo { font-size: 28px; }
    .search-btn { display: none; }
    .newsletter-link { display: none; }
    .masthead-divider { display: none; }
    .subscribe-btn { font-size: 12px; padding: 7px 14px; }
    .primary-nav-link { font-size: 13px; padding: 12px 14px; }
  }
</style>
