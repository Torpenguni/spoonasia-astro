>
  <section class="section">
    <div class="section-head">
      <div>
        <div class="section-eyebrow">— Stories</div>
        <h2 class="section-title">News &amp; observations</h2>
      </div>
    </div>
    <p style="color: var(--paper-mute); font-size: 18px; max-width: 60ch;">
      Short-form pieces (700–1,200 words) on what's happening in Thai F&amp;B this week. Coming soon.
    </p>
  </section>
</BaseLayout>
