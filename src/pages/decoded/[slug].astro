---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { articles, relatedArticles, type Article } from '../../data/content';

export function getStaticPaths() {
  return articles.map((a) => ({
    params: { slug: a.slug },
    props: { article: a },
  }));
}

interface Props {
  article: Article;
}

const { article } = Astro.props as Props;
const isFlagship = article.slug === 'why-foreign-coffee-chains-fail-thailand';
const related = relatedArticles(article.slug, 2);

// Flagship-only data
const tldrBullets = [
  "Most foreign chains misread Thai consumer behavior as Western convenience-seeking when it's actually social ritual.",
  'Premium-location rent compresses margin by 18–25% versus the original market.',
  'Successful entrants observed for 6–12 months. Failed ones opened within 90 days.',
  "The decision frame isn't 'Does our brand travel?' It's 'Does our unit economics survive 35% rent burden?'",
];

const numberCallouts = [
  { value: '90 min', label: 'Avg dwell time vs 35 min benchmark' },
  { value: '1.2×', label: 'Table turns vs 4× projection' },
  { value: '−65%', label: 'Revenue per seat vs pitch deck' },
];

const rentTable = [
  { loc: 'Sukhumvit (BTS Asok)', rent: '$95', burden: '34%', impact: '−22 pts', danger: true },
  { loc: 'Thonglor', rent: '$78', burden: '28%', impact: '−18 pts', danger: true },
  { loc: 'Silom CBD', rent: '$110', burden: '41%', impact: '−27 pts', danger: true },
  { loc: 'Ari (residential)', rent: '$42', burden: '15%', impact: '−6 pts', danger: false },
];

const numberedPrompts = [
  {
    q: "What's your dwell-time-adjusted revenue per seat?",
    a: "Not your menu price. Not your projected covers. The actual revenue your seat will generate per hour given Thai behavior.",
  },
  {
    q: "What's your rent burden at 1.2× table turn?",
    a: "Run the model at half the throughput you'd expect in Singapore or Tokyo. If margins don't survive that, your concept is fragile.",
  },
  {
    q: 'Are you optimizing for foot traffic or intent traffic?',
    a: 'Sukhumvit has the foot traffic. Ari has the intent. These are very different inventory.',
  },
];

const faqs = [
  {
    q: 'Are there foreign coffee chains succeeding in Thailand?',
    a: 'Yes. The patterns share three traits: residential or secondary CBD locations, multi-revenue-stream menus (food + beverage, not coffee-only), and entry through Thai operating partners rather than pure franchise.',
  },
  {
    q: "What's a healthy rent burden for café concepts in Bangkok?",
    a: 'Below 20% of revenue for sustainable margins. Most foreign-entered locations operate at 28–40%, which is why margin compression happens before any operational issues appear.',
  },
  {
    q: 'How long should foreign operators spend in-market before opening?',
    a: 'The expanding chain spent nine months operating a single test location before scaling. The closing chains opened multi-outlet within 90 days of signing leases.',
  },
];

const sources = [
  'CBRE Thailand — Q1 2026 Bangkok Retail Rental Report (March 2026)',
  'Krungsri Research — Thailand Coffee Industry Outlook 2026 (February 2026)',
  'Author interviews with 3 foreign coffee chain operators in Thailand (April–May 2026)',
  'Walking observation across 12 Bangkok neighborhoods (January–May 2026)',
];
---

<BaseLayout
  title={`${article.title} — SpoonAsia Decoded`}
  description={article.dek}
>
  {isFlagship ? (
    <>
      <!-- ARTICLE HEADER -->
      <section class="art-head">
        <div class="container-narrow">
          <div class="section-tag">▍ F&B Investment Intelligence</div>
          <h1 class="art-h1">
            Why foreign coffee chains keep failing in <em>Thailand</em>
          </h1>
          <p class="art-dek">
            Three international chains entered in 2023. Two are closing outlets in 2025.
            The difference wasn't the coffee.
          </p>
          <div class="art-meta">
            <span>By Torpenguin</span>
            <span class="sep">·</span>
            <span>13 May 2026</span>
            <span class="sep">·</span>
            <span>12 min read</span>
            <span class="sep">·</span>
            <span>Updated 2 days ago</span>
          </div>
        </div>
      </section>

      <!-- HERO IMAGE -->
      <figure class="art-figure">
        <div class="container-narrow">
          <div class="fig-image" aria-hidden="true"></div>
          <figcaption class="fig-cap">
            <span class="fig-num">FIG. 01</span>
            <span class="fig-text">— Sukhumvit Road, 09:00. Foot traffic doesn't equal customer traffic.</span>
          </figcaption>
        </div>
      </figure>

      <!-- TLDR / KEY TAKEAWAYS -->
      <section class="art-tldr-wrap">
        <div class="container-narrow">
          <aside class="tldr">
            <div class="tldr-label">Key Takeaways</div>
            <ul class="tldr-list">
              {tldrBullets.map((b) => (
                <li class="tldr-item">
                  <span class="tldr-arrow">→</span>
                  <span class="tldr-text">{b}</span>
                </li>
              ))}
            </ul>
          </aside>
        </div>
      </section>

      <!-- BODY -->
      <section class="art-body">
        <div class="container-narrow">
          <p class="body-p drop">
            Three foreign coffee chains entered Thailand in 2023. By Q4 2025, two are quietly closing outlets across Bangkok. One is expanding into Chiang Mai and Phuket. The brands had similar capital, similar coffee, and similar marketing budgets.
          </p>

          <p class="body-p">
            The difference wasn't the coffee. It was a single line in their pitch deck that nobody questioned hard enough: <em>"Thailand's growing middle class is adopting Western café culture."</em>
          </p>

          <p class="body-p">
            That sentence is technically true and strategically misleading. Let me explain why.
          </p>

          <h2 class="body-h2">What do Thai consumers actually buy when they buy coffee?</h2>

          <p class="body-p">
            In Singapore, a $6 latte is a productivity tool. In Bangkok, a $6 latte is a 90-minute social anchor. Same drink, completely different unit economics for the operator.
          </p>

          <blockquote class="pull">
            <p class="pull-text">
              The pitch deck shows revenue per cup. The P&L shows revenue per square meter per hour. These are not the same business.
            </p>
            <cite class="pull-cite">— Operational reality, foreign chain CFO</cite>
          </blockquote>

          <p class="body-p">
            If your model assumes 4-cup table turnover, and the actual behavior is 1.2-cup table turnover with a 90-minute average dwell time, your effective revenue per seat collapses by 65% — before anyone has done anything wrong operationally.
          </p>

          <div class="callouts">
            {numberCallouts.map((c) => (
              <div class="callout">
                <div class="co-value">{c.value}</div>
                <div class="co-label">{c.label}</div>
              </div>
            ))}
          </div>

          <p class="body-p">
            This isn't a Thai cultural failure. It's a forecasting failure. The brands modeled Thailand against Singapore data because the consultancy that wrote the deck modeled Thailand against Singapore data.
          </p>

          <h2 class="body-h2">How does rent compound the problem?</h2>

          <p class="body-p">
            Here's where it gets uncomfortable. The premium locations these chains chose — Sukhumvit, Thonglor, Silom — carry rent loads that look reasonable on a per-square-meter basis but become catastrophic when combined with the actual revenue model:
          </p>

          <div class="table-wrap">
            <div class="table-head-bar">
              <span class="tab-num">Tab. 01 — Rent burden by location, 2025</span>
              <span class="tab-src">Source: CBRE Thailand</span>
            </div>
            <table class="data-table">
              <thead>
                <tr>
                  <th class="cell-th">Location</th>
                  <th class="cell-th cell-num">Rent (USD/sqm)</th>
                  <th class="cell-th cell-num">Rent burden</th>
                  <th class="cell-th cell-num">Margin impact</th>
                </tr>
              </thead>
              <tbody>
                {rentTable.map((r) => (
                  <tr>
                    <td class="cell-td">{r.loc}</td>
                    <td class="cell-td cell-num">{r.rent}</td>
                    <td class="cell-td cell-num">{r.burden}</td>
                    <td class={r.danger ? 'cell-td cell-num cell-danger' : 'cell-td cell-num'}>
                      {r.impact}
                    </td>
                  </tr>
                ))}
              </tbody>
            </table>
          </div>

          <p class="body-p">
            The chain that's expanding in 2026? They opened in Ari. Their rent burden is 15%. Their unit economics actually work.
          </p>

          <figure class="art-figure-inline">
            <div class="fig-image" aria-hidden="true"></div>
            <figcaption class="fig-cap">
              <span class="fig-num">FIG. 02</span>
              <span class="fig-text">— Ari neighborhood, 14:00. Residential foot traffic = customer traffic.</span>
            </figcaption>
          </figure>

          <p class="body-p">
            This is the part that doesn't fit on a slide: location strategy in Thailand is not a "where do our customers shop" question. It's a "where can our rent burden survive Thai dwell-time patterns" question.
          </p>

          <h2 class="body-h2">What should foreign operators do differently?</h2>

          <p class="body-p">
            If you're evaluating Thailand for a coffee or café concept, the three questions to verify before signing any lease:
          </p>

          <ol class="prompts">
            {numberedPrompts.map((p, i) => (
              <li class="prompt">
                <span class="prompt-num">{String(i + 1).padStart(2, '0')}</span>
                <div class="prompt-body">
                  <strong class="prompt-q">{p.q}</strong>
                  <p class="prompt-a">{p.a}</p>
                </div>
              </li>
            ))}
          </ol>

          <blockquote class="pull">
            <p class="pull-text">
              Strip away the branding and look at the skeleton. Does this business actually work at Thai dwell-time?
            </p>
            <cite class="pull-cite">— Decision frame for any market entry</cite>
          </blockquote>
        </div>
      </section>

      <!-- FAQ -->
      <section class="art-faq">
        <div class="container-narrow">
          <div class="section-tag">▍ Common questions</div>
          <dl class="faq-list">
            {faqs.map((f) => (
              <div class="faq-item">
                <dt class="faq-q">{f.q}</dt>
                <dd class="faq-a">{f.a}</dd>
              </div>
            ))}
          </dl>
        </div>
      </section>

      <!-- SOURCES -->
      <section class="art-sources">
        <div class="container-narrow">
          <div class="section-tag">▍ Sources cited</div>
          <ol class="src-list">
            {sources.map((s, i) => (
              <li class="src-item">
                <span class="src-num">{String(i + 1).padStart(2, '0')}</span>
                <span class="src-text">{s}</span>
              </li>
            ))}
          </ol>
        </div>
      </section>

      <!-- AUTHOR BIO -->
      <section class="art-author">
        <div class="container-narrow">
          <div class="author">
            <div class="author-photo" aria-hidden="true"></div>
            <div class="author-body">
              <div class="author-name">Torpenguin</div>
              <div class="author-creds">Founder · SpoonAsia · 8 years Thai F&B operations</div>
              <p class="author-bio">
                Built Penguin Eat Shabu (40+ outlets, Bangkok). Now decodes Thailand's F&B landscape for international investors. Writes on unit economics, neighborhood alpha, and the gap between pitch decks and operational reality.
              </p>
            </div>
          </div>
        </div>
      </section>

      <!-- PENGUIN X CTA -->
      <section class="art-cta-wrap">
        <div class="container-narrow">
          <aside class="px-cta">
            <div class="px-label">Penguin X — Advisory</div>
            <h3 class="px-head">Considering Thailand for your next outlet?</h3>
            <p class="px-sub">
              Penguin X provides ground-truth due diligence for international F&B
              operators evaluating Thai market entry. Unit economics, neighborhood
              analysis, partner introductions.
            </p>
            <a href="/penguin-x" class="px-btn">Request a Briefing →</a>
          </aside>
        </div>
      </section>

      <!-- RELATED -->
      <section class="art-related">
        <div class="container-narrow">
          <div class="section-tag">▍ Related Decoded</div>
          <div class="rel-grid">
            {related.map((r) => (
              <article class="rel-card">
                <div class="rel-tag">{r.tag}</div>
                <h3 class="rel-h">
                  <a href={`/decoded/${r.slug}`}>{r.title}</a>
                </h3>
              </article>
            ))}
          </div>
        </div>
      </section>
    </>
  ) : (
    <!-- PLACEHOLDER FOR OTHER ARTICLES -->
    <section class="art-placeholder">
      <div class="container-narrow">
        <div class="section-tag">▍ Decoded</div>
        <h1 class="art-h1">{article.title}</h1>
        <p class="art-dek">{article.dek}</p>
        <div class="art-meta">
          <span>By {article.author}</span>
          <span class="sep">·</span>
          <span>{article.date}</span>
          <span class="sep">·</span>
          <span>{article.readTime}</span>
        </div>
        <div class="ph-notice">
          <div class="ph-label">In Production</div>
          <p class="ph-text">
            Full report in progress. Subscribe to <a href="/newsletter">The Dispatch</a>
            to receive it when published, or return to <a href="/decoded">all Decoded reports</a>.
          </p>
        </div>
      </div>
    </section>
  )}
</BaseLayout>

<style>
  .section-tag {
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--accent);
    margin-bottom: 18px;
  }

  /* ========== HEADER ========== */
  .art-head {
    padding: 64px 0 36px;
    border-bottom: 0.5px solid var(--hairline);
  }

  .art-h1 {
    font-family: var(--font-sans);
    font-size: clamp(34px, 4.4vw, 48px);
    font-weight: 500;
    line-height: 1.08;
    letter-spacing: -0.025em;
    color: var(--ink);
    margin-bottom: 20px;
  }
  .art-h1 em {
    font-family: var(--font-serif);
    font-style: italic;
    color: var(--accent);
    font-weight: 500;
  }

  .art-dek {
    font-family: var(--font-serif);
    font-style: italic;
    font-size: 20px;
    line-height: 1.5;
    color: var(--ink-soft);
    margin-bottom: 24px;
    max-width: 620px;
  }

  .art-meta {
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--ink-faint);
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
  }
  .art-meta .sep { color: var(--ink-mute); }

  /* ========== FIGURE ========== */
  .art-figure {
    padding: 36px 0;
  }
  .art-figure-inline {
    margin: 36px 0;
  }

  .fig-image {
    width: 100%;
    aspect-ratio: 16/9;
    background: linear-gradient(135deg, var(--hairline), var(--paper-warm));
  }

  .fig-cap {
    margin-top: 10px;
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }
  .fig-num { color: var(--accent); }
  .fig-text { color: var(--ink-faint); }

  /* ========== TLDR ========== */
  .art-tldr-wrap {
    padding: 12px 0 28px;
  }

  .tldr {
    background: var(--paper-warm);
    border-left: 2px solid var(--accent);
    padding: 22px 26px;
  }

  .tldr-label {
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--accent);
    margin-bottom: 14px;
  }

  .tldr-list {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .tldr-item {
    display: flex;
    gap: 10px;
    padding: 6px 0;
  }

  .tldr-arrow {
    flex-shrink: 0;
    color: var(--accent);
    font-family: var(--font-mono);
    font-weight: 500;
  }

  .tldr-text {
    font-family: var(--font-serif);
    font-size: 15px;
    line-height: 1.55;
    color: var(--ink);
  }

  /* ========== BODY ========== */
  .art-body {
    padding: 24px 0 48px;
  }

  .body-p {
    font-family: var(--font-serif);
    font-size: 18px;
    line-height: 1.75;
    color: var(--ink);
    margin-bottom: 26px;
  }
  .body-p em {
    font-style: italic;
  }

  .body-p.drop::first-letter {
    font-family: var(--font-sans);
    font-size: 64px;
    line-height: 0.95;
    float: left;
    font-weight: 500;
    margin: 4px 10px 0 0;
    color: var(--accent);
  }

  .body-h2 {
    font-family: var(--font-serif);
    font-size: 28px;
    font-weight: 500;
    line-height: 1.2;
    letter-spacing: -0.015em;
    color: var(--ink);
    margin: 48px 0 20px;
  }

  /* ========== PULL QUOTE ========== */
  .pull {
    border-left: 2px solid var(--accent);
    padding: 12px 0 12px 24px;
    margin: 36px 0;
  }
  .pull-text {
    font-family: var(--font-serif);
    font-style: italic;
    font-size: 24px;
    line-height: 1.35;
    color: var(--ink);
    margin-bottom: 14px;
  }
  .pull-cite {
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--ink-soft);
    font-style: normal;
  }

  /* ========== NUMBER CALLOUTS ========== */
  .callouts {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 24px;
    border-top: 0.5px solid var(--ink);
    border-bottom: 0.5px solid var(--hairline);
    padding: 24px 0;
    margin: 36px 0;
  }
  .callout {
    text-align: left;
  }
  .co-value {
    font-family: var(--font-mono);
    font-size: 32px;
    font-weight: 500;
    color: var(--accent);
    letter-spacing: -0.01em;
    margin-bottom: 8px;
    line-height: 1;
  }
  .co-label {
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--ink-soft);
    line-height: 1.4;
  }

  /* ========== DATA TABLE ========== */
  .table-wrap {
    margin: 36px 0;
    border-top: 0.5px solid var(--ink);
    border-bottom: 0.5px solid var(--hairline);
  }

  .table-head-bar {
    display: flex;
    justify-content: space-between;
    padding: 12px 0;
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    border-bottom: 0.5px solid var(--hairline);
  }
  .tab-num { color: var(--ink); }
  .tab-src { color: var(--ink-soft); }

  .data-table {
    width: 100%;
    border-collapse: collapse;
  }
  .cell-th {
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--ink-soft);
    font-weight: 500;
    text-align: left;
    padding: 14px 12px 14px 0;
    border-bottom: 0.5px solid var(--hairline);
  }
  .cell-num {
    text-align: right;
    padding-right: 0;
  }
  .cell-td {
    font-family: var(--font-serif);
    font-size: 14px;
    color: var(--ink);
    padding: 14px 12px 14px 0;
    border-bottom: 0.5px solid var(--hairline);
  }
  .cell-td.cell-num {
    font-family: var(--font-mono);
    font-size: 13px;
  }
  .cell-danger {
    color: var(--accent) !important;
  }
  tbody tr:last-child .cell-td {
    border-bottom: none;
  }

  /* ========== PROMPTS ========== */
  .prompts {
    list-style: none;
    padding: 0;
    margin: 28px 0;
  }
  .prompt {
    display: flex;
    gap: 18px;
    padding: 18px 0;
    border-bottom: 0.5px solid var(--hairline);
  }
  .prompt:last-child { border-bottom: none; }
  .prompt-num {
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.12em;
    color: var(--accent);
    flex-shrink: 0;
    min-width: 28px;
    padding-top: 4px;
  }
  .prompt-q {
    display: block;
    font-family: var(--font-serif);
    font-size: 17px;
    font-weight: 600;
    color: var(--ink);
    margin-bottom: 6px;
    line-height: 1.4;
  }
  .prompt-a {
    font-family: var(--font-serif);
    font-size: 15px;
    line-height: 1.6;
    color: var(--ink-soft);
  }

  /* ========== FAQ ========== */
  .art-faq {
    padding: 40px 0;
    border-top: 0.5px solid var(--hairline);
  }
  .faq-list {
    margin: 0;
  }
  .faq-item {
    padding: 20px 0;
    border-bottom: 0.5px solid var(--hairline);
  }
  .faq-item:last-child { border-bottom: none; }
  .faq-q {
    font-family: var(--font-serif);
    font-size: 18px;
    font-weight: 500;
    color: var(--ink);
    margin-bottom: 10px;
  }
  .faq-a {
    font-family: var(--font-serif);
    font-size: 15px;
    line-height: 1.65;
    color: var(--ink-soft);
    margin: 0;
  }

  /* ========== SOURCES ========== */
  .art-sources {
    padding: 40px 0;
    border-top: 0.5px solid var(--hairline);
  }
  .src-list {
    list-style: none;
    padding: 0;
    margin: 0;
  }
  .src-item {
    display: flex;
    gap: 12px;
    padding: 10px 0;
  }
  .src-num {
    font-family: var(--font-mono);
    font-size: 12px;
    color: var(--accent);
    flex-shrink: 0;
    min-width: 28px;
  }
  .src-text {
    font-family: var(--font-serif);
    font-size: 14px;
    line-height: 1.55;
    color: var(--ink);
  }

  /* ========== AUTHOR ========== */
  .art-author {
    padding: 36px 0;
    border-top: 0.5px solid var(--hairline);
    border-bottom: 0.5px solid var(--hairline);
  }
  .author {
    display: flex;
    gap: 18px;
    align-items: flex-start;
  }
  .author-photo {
    flex-shrink: 0;
    width: 56px;
    height: 56px;
    border-radius: 50%;
    background: linear-gradient(135deg, var(--hairline), var(--paper-warm));
  }
  .author-name {
    font-family: var(--font-sans);
    font-size: 15px;
    font-weight: 500;
    color: var(--ink);
    margin-bottom: 4px;
  }
  .author-creds {
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--ink-faint);
    margin-bottom: 10px;
  }
  .author-bio {
    font-family: var(--font-serif);
    font-size: 13px;
    line-height: 1.6;
    color: var(--ink-soft);
  }

  /* ========== PENGUIN X CTA ========== */
  .art-cta-wrap {
    padding: 32px 0 24px;
  }
  .px-cta {
    background: var(--ink);
    color: var(--paper);
    padding: 40px 32px;
    margin: 0;
  }
  .px-label {
