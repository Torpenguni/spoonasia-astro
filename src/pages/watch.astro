---
import BaseLayout from '../layouts/BaseLayout.astro';
import { videos } from '../data/content';

// Newest first (data is already in date order, top = newest)
const sorted = [...videos];
const featured = sorted[0];
const rest = sorted.slice(1);
---

<BaseLayout
  title="Watch — SpoonAsia"
  description="Long-form video breakdowns of brands, neighborhoods, and unit economics across Asian F&B. New episode every Tuesday."
>
  <section class="watch-head">
    <div class="container-narrow">
      <div class="section-tag">▍ Watch</div>
      <h1 class="watch-title">Video analysis on Thai F&B</h1>
      <p class="watch-dek">
        <em>
          Long-form breakdowns of brands, neighborhoods, and unit economics.
          New episode every Tuesday.
        </em>
      </p>
    </div>
  </section>

  <section class="featured-wrap">
    <div class="container">
      <article class="featured-ep">
        <a href={`/watch/${featured.slug}`} class="featured-thumb-link" aria-label={featured.title}>
          <div class="featured-thumb">
            <div class="play-btn" aria-hidden="true">▶</div>
            <div class="thumb-duration">{featured.duration}</div>
          </div>
        </a>

        <div class="featured-body">
          <div class="ep-tag">EP. {featured.episode}</div>
          <h2 class="featured-h">
            <a href={`/watch/${featured.slug}`}>{featured.title}</a>
          </h2>
          <p class="featured-dek-text">{featured.description}</p>
          <div class="meta">
            <span>{featured.date}</span>
            <span class="meta-sep">·</span>
            <span>{featured.views} views</span>
            <span class="meta-sep">·</span>
            <span>{featured.duration}</span>
          </div>
        </div>
      </article>
    </div>
  </section>

  <section class="grid-wrap">
    <div class="container">
      <div class="grid-head">
        <div class="section-tag">▍ Earlier episodes</div>
      </div>

      <div class="ep-grid">
        {
          rest.map((v) => (
            <a href={`/watch/${v.slug}`} class="ep-card">
              <div class="ep-thumb">
                <div class="play-btn-sm" aria-hidden="true">▶</div>
                <div class="thumb-duration">{v.duration}</div>
              </div>
              <div class="ep-card-tag">EP. {v.episode}</div>
              <h3 class="ep-card-h">{v.title}</h3>
              <div class="meta">
                <span>{v.date}</span>
                <span class="meta-sep">·</span>
                <span>{v.views} views</span>
              </div>
            </a>
          ))
        }
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .section-tag {
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--accent);
    margin-bottom: 16px;
  }

  /* ========== HEAD ========== */
  .watch-head {
    padding: 72px 0 40px;
  }
  .watch-title {
    font-family: var(--font-sans);
    font-size: clamp(40px, 5.5vw, 68px);
    font-weight: 500;
    letter-spacing: -0.03em;
    line-height: 1;
    color: var(--ink);
    margin-bottom: 22px;
  }
  .watch-dek {
    font-family: var(--font-serif);
    font-size: clamp(18px, 2vw, 22px);
    line-height: 1.5;
    color: var(--ink-soft);
    max-width: 620px;
  }
  .watch-dek em { font-style: italic; }

  /* ========== FEATURED EPISODE ========== */
  .featured-wrap {
    padding: 16px 0 48px;
    border-bottom: 0.5px solid var(--hairline);
  }

  .featured-ep {
    display: grid;
    grid-template-columns: 1.1fr 1fr;
    gap: 48px;
    align-items: center;
  }

  .featured-thumb-link {
    display: block;
    border-bottom: none;
    text-decoration: none;
  }

  .featured-thumb {
    position: relative;
    width: 100%;
    aspect-ratio: 16/9;
    background: linear-gradient(135deg, var(--ink) 0%, #2A2825 100%);
    display: flex;
    align-items: center;
    justify-content: center;
    transition: opacity 0.15s ease;
  }
  .featured-thumb-link:hover .featured-thumb { opacity: 0.92; }

  .play-btn {
    width: 72px;
    height: 72px;
    border-radius: 50%;
    background: var(--paper);
    color: var(--ink);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 22px;
    padding-left: 5px;
    transition: transform 0.15s ease;
  }
  .featured-thumb-link:hover .play-btn { transform: scale(1.08); }

  .thumb-duration {
    position: absolute;
    bottom: 12px;
    right: 12px;
    font-family: var(--font-mono);
    font-size: 11px;
    color: var(--paper);
    background: rgba(0, 0, 0, 0.72);
    padding: 4px 8px;
    letter-spacing: 0.04em;
  }

  .ep-tag {
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--accent);
    margin-bottom: 14px;
  }

  .featured-h {
    font-family: var(--font-serif);
    font-size: clamp(26px, 3.2vw, 36px);
    font-weight: 500;
    line-height: 1.15;
    letter-spacing: -0.015em;
    color: var(--ink);
    margin-bottom: 16px;
  }
  .featured-h a {
    color: inherit;
    text-decoration: none;
    border-bottom: none;
    transition: color 0.15s ease;
  }
  .featured-h a:hover { color: var(--accent); }

  .featured-dek-text {
    font-family: var(--font-serif);
    font-size: 17px;
    line-height: 1.55;
    color: var(--ink-soft);
    margin-bottom: 22px;
  }

  .meta {
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--ink-faint);
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
  }
  .meta-sep { color: var(--ink-mute); }

  /* ========== GRID ========== */
  .grid-wrap {
    padding: 48px 0 80px;
  }

  .grid-head {
    margin-bottom: 28px;
    padding-bottom: 16px;
    border-bottom: 0.5px solid var(--ink);
  }
  .grid-head .section-tag { margin-bottom: 0; }

  .ep-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 32px 28px;
  }

  .ep-card {
    display: block;
    text-decoration: none;
    border-bottom: none;
    color: inherit;
  }

  .ep-thumb {
    position: relative;
    width: 100%;
    aspect-ratio: 16/9;
    background: linear-gradient(135deg, var(--ink) 0%, #2A2825 100%);
    margin-bottom: 14px;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: opacity 0.15s ease;
  }
  .ep-card:hover .ep-thumb { opacity: 0.92; }

  .play-btn-sm {
    width: 48px;
    height: 48px;
    border-radius: 50%;
    background: var(--paper);
    color: var(--ink);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 14px;
    padding-left: 3px;
    transition: transform 0.15s ease;
  }
  .ep-card:hover .play-btn-sm { transform: scale(1.1); }

  .ep-card-tag {
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--accent);
    margin-bottom: 8px;
  }

  .ep-card-h {
    font-family: var(--font-serif);
    font-size: 19px;
    font-weight: 500;
    line-height: 1.25;
    letter-spacing: -0.01em;
    color: var(--ink);
    margin-bottom: 10px;
    transition: color 0.15s ease;
  }
  .ep-card:hover .ep-card-h { color: var(--accent); }

  /* ========== RESPONSIVE ========== */
  @media (max-width: 900px) {
    .watch-head { padding: 48px 0 32px; }
    .featured-ep {
      grid-template-columns: 1fr;
      gap: 20px;
    }
    .ep-grid { grid-template-columns: 1fr; gap: 28px; }
    .play-btn { width: 56px; height: 56px; font-size: 18px; }
  }
</style>
