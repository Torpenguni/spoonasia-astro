---
import BaseLayout from '../layouts/BaseLayout.astro';

const coming = [
  { name: 'Penguin Eat Shabu', note: '40+ outlet shabu chain. Supplier consolidation as moat.' },
  { name: 'After You', note: 'Premium dessert format. Mall flagship economics.' },
  { name: 'Inthanin', note: 'Bangchak\'s coffee play. Forecourt-led footprint.' },
  { name: 'Café Amazon', note: 'PTT-owned. 4,000+ outlets. The scale playbook nobody copies.' },
  { name: 'Greyhound Café', note: 'Lifestyle-led casual dining. Mall-tier survivor.' },
];
---

<BaseLayout
  title="Operator Profiles — SpoonAsia"
  description="In-depth profiles of Thai F&B operators. Unit economics, growth playbooks, and the structural moats."
>
  <section class="ph-head">
    <div class="container-narrow">
      <div class="section-tag">▍ Operator Profiles</div>
      <h1 class="ph-h1">The operators shaping Thai F&B.</h1>
      <p class="ph-dek">
        Long-form profiles of the chains and independents who built durable
        outlet economics — and the ones who didn't. We tear apart their
        P&L, their supply chain, and the moat that compounds.
      </p>
    </div>
  </section>

  <section class="ph-body">
    <div class="container-narrow">
      <div class="ph-notice">
        <div class="ph-label">In Production</div>
        <p class="ph-text">
          The first five profiles are being researched. Operators below.
          For early access when published, subscribe to <a href="/newsletter">The Dispatch</a>.
        </p>
      </div>

      <ol class="ph-list">
        {coming.map((c, i) => (
          <li class="ph-item">
            <span class="ph-num">{String(i + 1).padStart(2, '0')}</span>
            <div class="ph-body-inner">
              <div class="ph-name">{c.name}</div>
              <p class="ph-note">{c.note}</p>
            </div>
          </li>
        ))}
      </ol>

      <p class="ph-redirect">
        Meanwhile, read our existing coverage in <a href="/analysis">Analysis</a> →
      </p>
    </div>
  </section>
</BaseLayout>

<style>
  .section-tag {
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--accent);
    margin-bottom: 18px;
  }
  .ph-head {
    padding: 72px 0 40px;
    border-bottom: 0.5px solid var(--hairline);
  }
  .ph-h1 {
    font-family: var(--font-sans);
    font-size: clamp(36px, 5vw, 56px);
    font-weight: 500;
    letter-spacing: -0.03em;
    line-height: 1.05;
    color: var(--ink);
    margin-bottom: 20px;
  }
  .ph-dek {
    font-family: var(--font-serif);
    font-size: clamp(17px, 1.8vw, 20px);
    line-height: 1.55;
    color: var(--ink-soft);
    max-width: 640px;
  }
  .ph-body {
    padding: 48px 0 80px;
  }
  .ph-notice {
    background: var(--paper-warm);
    border-left: 2px solid var(--accent);
    padding: 22px 26px;
    margin-bottom: 40px;
  }
  .ph-label {
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--accent);
    margin-bottom: 10px;
  }
  .ph-text {
    font-family: var(--font-serif);
    font-size: 15px;
    line-height: 1.6;
    color: var(--ink);
  }
  .ph-text a {
    color: var(--ink);
    border-bottom: 0.5px solid var(--ink-faint);
    text-decoration: none;
  }
  .ph-text a:hover {
    color: var(--accent);
    border-bottom-color: var(--accent);
  }

  .ph-list {
    list-style: none;
    padding: 0;
    margin: 0;
  }
  .ph-item {
    display: flex;
    gap: 22px;
    padding: 22px 0;
    border-top: 0.5px solid var(--hairline);
  }
  .ph-item:last-child {
    border-bottom: 0.5px solid var(--hairline);
  }
  .ph-num {
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.12em;
    color: var(--accent);
    flex-shrink: 0;
    min-width: 28px;
    padding-top: 4px;
  }
  .ph-name {
    font-family: var(--font-sans);
    font-size: 19px;
    font-weight: 700;
    letter-spacing: -0.015em;
    color: var(--ink);
    margin-bottom: 6px;
  }
  .ph-note {
    font-family: var(--font-serif);
    font-size: 15px;
    line-height: 1.55;
    color: var(--ink-soft);
  }

  .ph-redirect {
    margin-top: 36px;
    font-family: var(--font-serif);
    font-size: 16px;
    color: var(--ink-soft);
  }
  .ph-redirect a {
    color: var(--ink);
    border-bottom: 0.5px solid var(--ink-faint);
    text-decoration: none;
  }
  .ph-redirect a:hover {
    color: var(--accent);
    border-bottom-color: var(--accent);
  }
</style>
