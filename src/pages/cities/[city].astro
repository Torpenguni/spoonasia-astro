---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { cities, articles } from '../../data/content';

export function getStaticPaths() {
  return cities.map((c) => ({
    params: { city: c.slug },
    props: { city: c },
  }));
}

const { city } = Astro.props;

const cityArticles = articles
  .filter((a) =>
    [a.title, a.dek, a.body].some((s) =>
      s.toLowerCase().includes(city.name.toLowerCase())
    )
  )
  .slice(0, 6);
---

<BaseLayout
  title={`${city.name} — SpoonAsia`}
  description={`F&B intelligence on ${city.name}: ${city.tagline}`}
>
  <section class="city-hero">
    <div class="container-narrow">
      <div class="city-eyebrow">Cities</div>
      <h1 class="city-title">{city.name}</h1>
      <p class="city-tagline">{city.tagline}</p>
      <p class="city-desc">{city.description}</p>
    </div>
  </section>

  <section class="city-stats">
    <div class="container">
      <div class="stats-head">
        <h2 class="section-h">By the numbers</h2>
      </div>
      <div class="stats-grid">
        {
          city.stats.map((s) => (
            <div class="stat-card">
              <div class="stat-value">{s.value}</div>
              <div class="stat-label">{s.label}</div>
              {s.note && <div class="stat-note">{s.note}</div>}
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <section class="city-zones">
    <div class="container">
      <div class="stats-head">
        <h2 class="section-h">F&B zones to watch</h2>
      </div>
      <ol class="zones-list">
        {
          city.zones.map((z, i) => (
            <li class="zone-item">
              <span class="zone-num">{String(i + 1).padStart(2, '0')}</span>
              <div class="zone-body">
                <div class="zone-name">{z.name}</div>
                <p class="zone-note">{z.note}</p>
              </div>
            </li>
          ))
        }
      </ol>
    </div>
  </section>

  {
    cityArticles.length > 0 && (
      <section class="city-articles">
        <div class="container">
          <div class="stats-head">
            <h2 class="section-h">Coverage</h2>
            <a href="/decoded" class="head-more">
              All Coverage →
            </a>
          </div>
          <div class="articles-grid">
            {cityArticles.map((a) => (
              <article class="article-card">
                <div class="article-card-image" aria-hidden="true" />
                <a href={`/decoded/${a.category}`} class="article-card-tag">
                  {a.tag}
                </a>
                <h3 class="article-card-headline">
                  <a href={`/decoded/${a.slug}`}>{a.title}</a>
                </h3>
                <p class="article-card-dek">{a.dek}</p>
                <div class="article-card-meta">{a.date}</div>
              </article>
            ))}
          </div>
        </div>
      </section>
    )
  }
</BaseLayout>

<style>
  .city-hero {
    padding: 72px 0 48px;
    border-bottom: 0.5px solid var(--hairline);
  }

  .city-eyebrow {
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--accent);
    margin-bottom: 16px;
  }

  .city-title {
    font-family: var(--font-sans);
    font-size: clamp(56px, 7vw, 96px);
    font-weight: 800;
    letter-spacing: -0.04em;
    line-height: 0.95;
    color: var(--ink);
    margin-bottom: 18px;
  }

  .city-tagline {
    font-family: var(--font-serif);
    font-size: clamp(20px, 2.2vw, 26px);
    line-height: 1.35;
    color: var(--ink);
    margin-bottom: 18px;
    max-width: 620px;
  }

  .city-desc {
    font-family: var(--font-serif);
    font-size: 17px;
    line-height: 1.55;
    color: var(--ink-soft);
    max-width: 620px;
  }

  .stats-head {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    border-top: 2px solid var(--ink);
    padding-top: 16px;
    margin-bottom: 32px;
  }

  .section-h {
    font-family: var(--font-sans);
    font-size: clamp(26px, 3vw, 34px);
    font-weight: 800;
    letter-spacing: -0.025em;
    color: var(--ink);
  }

  .head-more {
    font-family: var(--font-sans);
    font-size: 13px;
    font-weight: 600;
    color: var(--ink-soft);
    text-decoration: none;
    border-bottom: none;
  }
  .head-more:hover { color: var(--accent); }

  .city-stats {
    padding: 48px 0;
    border-bottom: 0.5px solid var(--hairline);
  }

  .stats-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 24px;
  }

  .stat-card {
    padding: 24px 0;
    border-top: 0.5px solid var(--ink);
  }

  .stat-value {
    font-family: var(--font-sans);
    font-size: clamp(28px, 3vw, 38px);
    font-weight: 800;
    letter-spacing: -0.02em;
    color: var(--ink);
    line-height: 1;
    margin-bottom: 12px;
  }

  .stat-label {
    font-family: var(--font-sans);
    font-size: 13px;
    font-weight: 600;
    color: var(--ink-soft);
    margin-bottom: 6px;
  }

  .stat-note {
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--ink-faint);
  }

  .city-zones {
    padding: 48px 0;
    border-bottom: 0.5px solid var(--hairline);
  }

  .zones-list {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .zone-item {
    display: flex;
    gap: 24px;
    align-items: flex-start;
    padding: 24px 0;
    border-bottom: 0.5px solid var(--hairline);
  }
  .zone-item:last-child { border-bottom: none; }

  .zone-num {
    font-family: var(--font-sans);
    font-size: 32px;
    font-weight: 800;
    color: var(--accent);
    letter-spacing: -0.02em;
    flex-shrink: 0;
    min-width: 48px;
    line-height: 1;
  }

  .zone-name {
    font-family: var(--font-sans);
    font-size: 20px;
    font-weight: 700;
    letter-spacing: -0.015em;
    color: var(--ink);
    margin-bottom: 6px;
  }

  .zone-note {
    font-family: var(--font-serif);
    font-size: 15px;
    line-height: 1.55;
    color: var(--ink-soft);
  }

  .city-articles {
    padding: 48px 0 64px;
  }

  .articles-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 32px 28px;
  }

  .article-card {
    display: flex;
    flex-direction: column;
  }

  .article-card-image {
    width: 100%;
    aspect-ratio: 16/10;
    background: linear-gradient(135deg, var(--paper-mute) 0%, var(--paper-warm) 100%);
    margin-bottom: 14px;
  }

  .article-card-tag {
    font-family: var(--font-sans);
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--accent);
    text-decoration: none;
    border-bottom: none;
    margin-bottom: 8px;
  }

  .article-card-headline {
    font-family: var(--font-sans);
    font-size: 19px;
    font-weight: 700;
    line-height: 1.2;
    letter-spacing: -0.015em;
    margin-bottom: 8px;
  }
  .article-card-headline a {
    color: var(--ink);
    text-decoration: none;
    border-bottom: none;
    transition: color 0.15s ease;
  }
  .article-card-headline a:hover { color: var(--accent); }

  .article-card-dek {
    font-family: var(--font-serif);
    font-size: 14px;
    line-height: 1.5;
    color: var(--ink-soft);
    margin-bottom: 10px;
  }

  .article-card-meta {
    font-family: var(--font-sans);
    font-size: 11px;
    color: var(--ink-faint);
    margin-top: auto;
  }

  @media (max-width: 1024px) {
    .stats-grid {
      grid-template-columns: repeat(2, 1fr);
    }
    .articles-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 768px) {
    .stats-grid {
      grid-template-columns: 1fr 1fr;
      gap: 16px;
    }
    .articles-grid {
      grid-template-columns: 1fr;
    }
    .zone-num { font-size: 24px; min-width: 36px; }
    .zone-name { font-size: 18px; }
  }
</style>
