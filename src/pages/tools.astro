---
import BaseLayout from '../layouts/BaseLayout.astro';

const tools = [
  { tag: 'Calculator', name: 'Unit Economics Sandbox', note: 'Inputs: rent, COGS, labor, dwell time, table turn. Outputs: payback period at Thai vs Singapore throughput.' },
  { tag: 'Calculator', name: 'Rent Burden Stress Test', note: 'Run your concept against 0.6×, 1.0×, and 1.4× projected revenue. See where margin breaks.' },
  { tag: 'Framework', name: 'Neighborhood Selection Matrix', note: 'Score Bangkok zones against your concept profile. Foot traffic, intent traffic, rent curve, operator density.' },
  { tag: 'Checklist', name: 'Pre-Lease Diligence Worksheet', note: '38 questions to verify before signing a Thai retail F&B lease. Covers CAM, escalators, key money, fit-out, regulatory.' },
];
---

<BaseLayout
  title="Tools — SpoonAsia"
  description="Calculators, frameworks, and checklists for international F&B operators evaluating Thailand."
>
  <section class="ph-head">
    <div class="container-narrow">
      <div class="section-tag">▍ Tools</div>
      <h1 class="ph-h1">Calculators and frameworks. <em>Built from the P&L.</em></h1>
      <p class="ph-dek">
        Interactive tools that translate Thai F&B operational reality into
        decisions. Pre-lease diligence, unit-economics stress tests, and the
        neighborhood selection matrix we use internally.
      </p>
    </div>
  </section>

  <section class="ph-body">
    <div class="container-narrow">
      <div class="ph-notice">
        <div class="ph-label">In Production</div>
        <p class="ph-text">
          The first tools ship in Q3 2026. For early-access beta when ready,
          subscribe to <a href="/newsletter">The Dispatch</a> — beta opens to
          newsletter subscribers first.
        </p>
      </div>

      <div class="tool-list">
        {tools.map((t) => (
          <article class="tool-item">
            <div class="tool-tag">{t.tag}</div>
            <h3 class="tool-name">{t.name}</h3>
            <p class="tool-note">{t.note}</p>
          </article>
        ))}
      </div>

      <p class="ph-redirect">
        Meanwhile, read our existing coverage in <a href="/analysis">Analysis</a> →
      </p>
    </div>
  </section>
</BaseLayout>

<style>
  .section-tag {
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--accent);
    margin-bottom: 18px;
  }
  .ph-head {
    padding: 72px 0 40px;
    border-bottom: 0.5px solid var(--hairline);
  }
  .ph-h1 {
    font-family: var(--font-sans);
    font-size: clamp(36px, 5vw, 56px);
    font-weight: 500;
    letter-spacing: -0.03em;
    line-height: 1.05;
    color: var(--ink);
    margin-bottom: 20px;
  }
  .ph-h1 em {
    font-family: var(--font-serif);
    font-style: italic;
    color: var(--accent);
    font-weight: 500;
  }
  .ph-dek {
    font-family: var(--font-serif);
    font-size: clamp(17px, 1.8vw, 20px);
    line-height: 1.55;
    color: var(--ink-soft);
    max-width: 640px;
  }
  .ph-body { padding: 48px 0 80px; }

  .ph-notice {
    background: var(--paper-warm);
    border-left: 2px solid var(--accent);
    padding: 22px 26px;
    margin-bottom: 40px;
  }
  .ph-label {
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--accent);
    margin-bottom: 10px;
  }
  .ph-text {
    font-family: var(--font-serif);
    font-size: 15px;
    line-height: 1.6;
    color: var(--ink);
  }
  .ph-text a {
    color: var(--ink);
    border-bottom: 0.5px solid var(--ink-faint);
    text-decoration: none;
  }
  .ph-text a:hover {
    color: var(--accent);
    border-bottom-color: var(--accent);
  }

  .tool-list { display: grid; gap: 0; }
  .tool-item {
    padding: 24px 0;
    border-top: 0.5px solid var(--hairline);
  }
  .tool-item:last-child {
    border-bottom: 0.5px solid var(--hairline);
  }
  .tool-tag {
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--accent);
    margin-bottom: 10px;
  }
  .tool-name {
    font-family: var(--font-serif);
    font-size: 21px;
    font-weight: 500;
    line-height: 1.25;
    letter-spacing: -0.01em;
    color: var(--ink);
    margin-bottom: 8px;
  }
  .tool-note {
    font-family: var(--font-serif);
    font-size: 14px;
    line-height: 1.55;
    color: var(--ink-soft);
  }

  .ph-redirect {
    margin-top: 36px;
    font-family: var(--font-serif);
    font-size: 16px;
    color: var(--ink-soft);
  }
  .ph-redirect a {
    color: var(--ink);
    border-bottom: 0.5px solid var(--ink-faint);
    text-decoration: none;
  }
  .ph-redirect a:hover {
    color: var(--accent);
    border-bottom-color: var(--accent);
  }
</style>
