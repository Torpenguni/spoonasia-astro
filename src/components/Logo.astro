---
// Reusable SpoonAsia logo SVG
interface Props {
  className?: string;
  showTagline?: boolean;
}
const { className = '', showTagline = true } = Astro.props;
---

<svg class={className} viewBox="0 0 600 200" xmlns="http://www.w3.org/2000/svg" aria-label="SpoonAsia">
  <path d="M 150 72 L 137 72 L 137 128 L 150 128" fill="none" stroke="#E07A47" stroke-width="3" stroke-linecap="square"/>
  <text x="300" y="114" text-anchor="middle" font-family="Inter, sans-serif" font-size="42" font-weight="500" fill="#FAFAF7" letter-spacing="-0.018em">SpoonAsia</text>
  <path d="M 450 72 L 463 72 L 463 128 L 450 128" fill="none" stroke="#E07A47" stroke-width="3" stroke-linecap="square"/>
  {showTagline && (
    <>
      <line x1="160" y1="155" x2="240" y2="155" stroke="#FAFAF7" stroke-width="0.5"/>
      <text x="300" y="160" text-anchor="middle" font-family="Inter, sans-serif" font-size="11" fill="#FAFAF7" letter-spacing="0.32em">DECODING THAI F&amp;B</text>
      <line x1="360" y1="155" x2="440" y2="155" stroke="#FAFAF7" stroke-width="0.5"/>
    </>
  )}
</svg>
