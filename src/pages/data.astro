---
import BaseLayout from '../layouts/BaseLayout.astro';

const datasets = [
  { tag: 'Rents', name: 'Bangkok F&B retail rent index', note: 'Quarterly. Premium mall, CBD, secondary corridor, residential. Source: CBRE Thailand + field verification.' },
  { tag: 'Operators', name: 'Thai F&B chain footprint tracker', note: 'Outlet counts by quarter for the 40 largest casual-dining chains. Includes openings, closures, format conversions.' },
  { tag: 'Suppliers', name: 'Specialty coffee bean import flow', note: 'Volume and origin breakdown for the two dominant Thai importers. Annual.' },
  { tag: 'Markets', name: 'SET F&B subindex composition', note: 'Sector breakdown by market cap. Foreign vs domestic ownership. Quarterly.' },
  { tag: 'Consumer', name: 'Thai delivery vs dine-in share', note: 'GrabFood + LineMan + dine-in receipts. Monthly. Three Bangkok zones tracked.' },
];
---

<BaseLayout
  title="Data & Charts — SpoonAsia"
  description="Original datasets on Thai F&B: rents, operators, suppliers, market structure, and consumer behavior."
>
  <section class="ph-head">
    <div class="container-narrow">
      <div class="section-tag">▍ Data & Charts</div>
      <h1 class="ph-h1">Original datasets on Thai F&B.</h1>
      <p class="ph-dek">
        Quarterly rent indices, operator footprint trackers, supplier flow
        data, and consumer behavior series. Each dataset is documented with
        sourcing, methodology, and known limitations.
      </p>
    </div>
  </section>

  <section class="ph-body">
    <div class="container-narrow">
      <div class="ph-notice">
        <div class="ph-label">In Production</div>
        <p class="ph-text">
          The first datasets publish in Q2 2026. Pipeline below.
          For data release alerts, subscribe to <a href="/newsletter">The Dispatch</a>.
        </p>
      </div>

      <div class="ds-list">
        {datasets.map((d) => (
          <article class="ds-item">
            <div class="ds-tag">{d.tag}</div>
            <h3 class="ds-name">{d.name}</h3>
            <p class="ds-note">{d.note}</p>
          </article>
        ))}
      </div>

      <p class="ph-redirect">
        Meanwhile, read our existing coverage in <a href="/analysis">Analysis</a> →
      </p>
    </div>
  </section>
</BaseLayout>

<style>
  .section-tag {
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--accent);
    margin-bottom: 18px;
  }
  .ph-head {
    padding: 72px 0 40px;
    border-bottom: 0.5px solid var(--hairline);
  }
  .ph-h1 {
    font-family: var(--font-sans);
    font-size: clamp(36px, 5vw, 56px);
    font-weight: 500;
    letter-spacing: -0.03em;
    line-height: 1.05;
    color: var(--ink);
    margin-bottom: 20px;
  }
  .ph-dek {
    font-family: var(--font-serif);
    font-size: clamp(17px, 1.8vw, 20px);
    line-height: 1.55;
    color: var(--ink-soft);
    max-width: 640px;
  }
  .ph-body { padding: 48px 0 80px; }

  .ph-notice {
    background: var(--paper-warm);
    border-left: 2px solid var(--accent);
    padding: 22px 26px;
    margin-bottom: 40px;
  }
  .ph-label {
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--accent);
    margin-bottom: 10px;
  }
  .ph-text {
    font-family: var(--font-serif);
    font-size: 15px;
    line-height: 1.6;
    color: var(--ink);
  }
  .ph-text a {
    color: var(--ink);
    border-bottom: 0.5px solid var(--ink-faint);
    text-decoration: none;
  }
  .ph-text a:hover {
    color: var(--accent);
    border-bottom-color: var(--accent);
  }

  .ds-list { display: grid; gap: 0; }
  .ds-item {
    padding: 24px 0;
    border-top: 0.5px solid var(--hairline);
  }
  .ds-item:last-child {
    border-bottom: 0.5px solid var(--hairline);
  }
  .ds-tag {
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--accent);
    margin-bottom: 10px;
  }
  .ds-name {
    font-family: var(--font-serif);
    font-size: 21px;
    font-weight: 500;
    line-height: 1.25;
    letter-spacing: -0.01em;
    color: var(--ink);
    margin-bottom: 8px;
  }
  .ds-note {
    font-family: var(--font-serif);
    font-size: 14px;
    line-height: 1.55;
    color: var(--ink-soft);
  }

  .ph-redirect {
    margin-top: 36px;
    font-family: var(--font-serif);
    font-size: 16px;
    color: var(--ink-soft);
  }
  .ph-redirect a {
    color: var(--ink);
    border-bottom: 0.5px solid var(--ink-faint);
    text-decoration: none;
  }
  .ph-redirect a:hover {
    color: var(--accent);
    border-bottom-color: var(--accent);
  }
</style>
