---
import BaseLayout from '../layouts/BaseLayout.astro';

const services = [
  {
    num: '01',
    head: 'Unit Economics Audit',
    body: 'We tear apart your pro forma against Thai cost structure and dwell-time data. The output is a P&L that maps to operational reality, not Singapore comparables.',
  },
  {
    num: '02',
    head: 'Neighborhood Selection',
    body: 'Where does your concept actually work in Bangkok? We map nine neighborhoods against your unit economics, rent burden tolerance, and customer-intent profile.',
  },
  {
    num: '03',
    head: 'Partner Introductions',
    body: 'The right Thai operating partner is the difference between a clean entry and a 24-month bleed. We make selective introductions from a network built over 8 years of operations.',
  },
  {
    num: '04',
    head: 'Market Entry Strategy',
    body: 'A decision document that says what to do, in what order, with what capital. We end with go / no-go / wait clarity, not a 60-slide deck.',
  },
];

const process = [
  { num: '01', label: 'Brief', body: '90-minute call. You walk us through the concept, the markets you have considered, and the constraints.' },
  { num: '02', label: 'Field Work', body: '2–6 weeks on the ground in Bangkok. We walk locations, interview operators, and run the numbers.' },
  { num: '03', label: 'Analysis', body: 'We build the model, the neighborhood comparison, and the partner shortlist offline. No status decks in between.' },
  { num: '04', label: 'Decision Document', body: 'A 12–20 page document plus working model. One read and you know what to do next.' },
];

const work = [
  {
    client: 'Singapore-based coffee chain',
    engagement: 'Market Entry Audit · 2025',
    outcome: 'Recommended postponing Bangkok entry for 6 months and switching from Sukhumvit flagship to Ari pilot. Client signed Ari lease in Q4 2025.',
  },
  {
    client: 'Japanese specialty F&B operator',
    engagement: 'Neighborhood Selection · 2024',
    outcome: 'Mapped 11 Bangkok zones against client unit economics. Identified 3 viable locations. Two are now open and tracking ahead of pro forma.',
  },
  {
    client: 'European family office',
    engagement: 'Full Advisory · 2024–25',
    outcome: 'Built thesis for ASEAN F&B portfolio focused on Thai operator partnerships. Five investments completed; all five tracking above plan at 18 months.',
  },
];

const tiers = [
  {
    name: 'Brief Consult',
    price: '$5K',
    desc: 'One 90-minute working session plus written follow-up. Use for a specific question or a go / no-go on a concept.',
  },
  {
    name: 'Market Entry Audit',
    price: '$15K–25K',
    desc: 'Full unit economics review, neighborhood selection, and decision document. 4–6 week engagement. The most common starting point.',
  },
  {
    name: 'Full Advisory',
    price: '$40K+',
    desc: 'Retainer engagement including partner introductions, lease review, and ongoing decision support. Custom-scoped.',
  },
];
---

<BaseLayout
  title="Penguin X — Advisory · SpoonAsia"
  description="Ground-truth due diligence for Thai market entry. Unit economics audits, neighborhood selection, and partner introductions for international F&B operators."
>
  <section class="px-hero">
    <div class="container-narrow">
      <div class="section-tag">▍ Penguin X — Advisory</div>
      <h1 class="px-h1">
        Ground-truth due diligence for <em>Thai market entry</em>
      </h1>
      <p class="px-dek">
        <em>
          For international F&B operators, suppliers, and investors evaluating Thailand.
          We help you see what the local broker can't show you and the consultancy won't tell you.
        </em>
      </p>
      <a href="#contact" class="px-cta-btn">Request a Briefing →</a>
    </div>
  </section>

  <section class="px-services">
    <div class="container">
      <div class="sec-head">
        <div class="section-tag">▍ What we do</div>
      </div>
      <div class="svc-grid">
        {
          services.map((s) => (
            <article class="svc-card">
              <div class="svc-num">{s.num}</div>
              <h3 class="svc-head">{s.head}</h3>
              <p class="svc-body">{s.body}</p>
            </article>
          ))
        }
      </div>
    </div>
  </section>

  <section class="px-process">
    <div class="container">
      <div class="sec-head">
        <div class="section-tag">▍ How engagements work</div>
      </div>
      <ol class="proc-row">
        {
          process.map((p) => (
            <li class="proc-step">
              <div class="proc-num">{p.num}</div>
              <div class="proc-label">{p.label}</div>
              <p class="proc-body">{p.body}</p>
            </li>
          ))
        }
      </ol>
    </div>
  </section>

  <section class="px-work">
    <div class="container">
      <div class="sec-head">
        <div class="section-tag">▍ Selected work</div>
        <p class="sec-note">
          Engagements are confidential. Client identities are not disclosed.
        </p>
      </div>
      <div class="work-grid">
        {
          work.map((w) => (
            <article class="work-card">
              <div class="work-client">{w.client}</div>
              <div class="work-eng">{w.engagement}</div>
              <p class="work-outcome">{w.outcome}</p>
            </article>
          ))
        }
      </div>
    </div>
  </section>

  <section class="px-pricing">
    <div class="container">
      <div class="sec-head">
        <div class="section-tag">▍ Pricing</div>
        <h2 class="px-pricing-h">Engagements typically begin at $5K.</h2>
      </div>
      <div class="tier-grid">
        {
          tiers.map((t) => (
            <div class="tier-card">
              <div class="tier-price">{t.price}</div>
              <div class="tier-name">{t.name}</div>
              <p class="tier-desc">{t.desc}</p>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <section class="px-contact" id="contact">
    <div class="container-narrow">
      <div class="sec-head">
        <div class="section-tag">▍ Request a Briefing</div>
        <p class="sec-note">We respond within 48 hours.</p>
      </div>

      <form class="contact-form" onsubmit="event.preventDefault()">
        <div class="form-row">
          <label class="form-field">
            <span class="form-label">Name</span>
            <input type="text" name="name" class="form-input" required />
          </label>
          <label class="form-field">
            <span class="form-label">Email</span>
            <input type="email" name="email" class="form-input" required />
          </label>
        </div>
        <div class="form-row">
          <label class="form-field">
            <span class="form-label">Company</span>
            <input type="text" name="company" class="form-input" />
          </label>
          <label class="form-field">
            <span class="form-label">Country</span>
            <input type="text" name="country" class="form-input" />
          </label>
        </div>
        <label class="form-field form-field-full">
          <span class="form-label">Brief description</span>
          <textarea name="brief" rows="5" class="form-textarea" placeholder="What concept, what markets, what stage."></textarea>
        </label>
        <button type="submit" class="form-submit">Request Briefing →</button>
        <p class="form-note">We respond within 48 hours.</p>
      </form>
    </div>
  </section>
</BaseLayout>

<style>
  .section-tag {
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--accent);
    margin-bottom: 16px;
  }

  /* ========== HERO ========== */
  .px-hero {
    padding: 72px 0 56px;
    border-bottom: 0.5px solid var(--hairline);
  }
  .px-h1 {
    font-family: var(--font-sans);
    font-size: clamp(40px, 5.5vw, 60px);
    font-weight: 500;
    line-height: 1.05;
    letter-spacing: -0.03em;
    color: var(--ink);
    margin-bottom: 24px;
  }
  .px-h1 em {
    font-family: var(--font-serif);
    font-style: italic;
    color: var(--accent);
    font-weight: 500;
  }
  .px-dek {
    font-family: var(--font-serif);
    font-size: clamp(18px, 2vw, 22px);
    line-height: 1.5;
    color: var(--ink-soft);
    margin-bottom: 32px;
    max-width: 620px;
  }
  .px-dek em { font-style: italic; }

  .px-cta-btn {
    display: inline-block;
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    padding: 14px 24px;
    background: var(--ink);
    color: var(--paper);
    text-decoration: none;
    border-bottom: none;
    transition: background 0.15s ease;
  }
  .px-cta-btn:hover {
    background: var(--accent);
  }

  /* ========== SECTION HEAD ========== */
  .sec-head {
    margin-bottom: 36px;
    padding-bottom: 16px;
    border-bottom: 0.5px solid var(--ink);
  }
  .sec-head .section-tag { margin-bottom: 10px; }
  .sec-note {
    font-family: var(--font-serif);
    font-size: 14px;
    color: var(--ink-soft);
    margin-top: 8px;
  }

  /* ========== SERVICES ========== */
  .px-services {
    padding: 56px 0;
    border-bottom: 0.5px solid var(--hairline);
  }
  .svc-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 36px 48px;
  }
  .svc-card {
    border-top: 0.5px solid var(--hairline);
    padding-top: 20px;
  }
  .svc-num {
    font-family: var(--font-mono);
    font-size: 13px;
    letter-spacing: 0.12em;
    color: var(--accent);
    margin-bottom: 14px;
  }
  .svc-head {
    font-family: var(--font-serif);
    font-size: 24px;
    font-weight: 500;
    letter-spacing: -0.015em;
    color: var(--ink);
    margin-bottom: 12px;
  }
  .svc-body {
    font-family: var(--font-serif);
    font-size: 15px;
    line-height: 1.6;
    color: var(--ink-soft);
  }

  /* ========== PROCESS ========== */
  .px-process {
    padding: 56px 0;
    border-bottom: 0.5px solid var(--hairline);
  }
  .proc-row {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 28px;
  }
  .proc-step {
    border-top: 0.5px solid var(--ink);
    padding-top: 16px;
  }
  .proc-num {
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.12em;
    color: var(--accent);
    margin-bottom: 10px;
  }
  .proc-label {
    font-family: var(--font-sans);
    font-size: 18px;
    font-weight: 500;
    color: var(--ink);
    margin-bottom: 10px;
  }
  .proc-body {
    font-family: var(--font-serif);
    font-size: 14px;
    line-height: 1.55;
    color: var(--ink-soft);
  }

  /* ========== WORK ========== */
  .px-work {
    padding: 56px 0;
    border-bottom: 0.5px solid var(--hairline);
  }
  .work-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 28px;
  }
  .work-card {
    background: var(--paper-warm);
    padding: 24px;
    border-left: 2px solid var(--accent);
  }
  .work-client {
    font-family: var(--font-sans);
    font-size: 17px;
    font-weight: 500;
    color: var(--ink);
    margin-bottom: 8px;
    letter-spacing: -0.01em;
  }
  .work-eng {
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--accent);
    margin-bottom: 16px;
  }
  .work-outcome {
    font-family: var(--font-serif);
    font-size: 14px;
    line-height: 1.6;
    color: var(--ink);
  }

  /* ========== PRICING ========== */
  .px-pricing {
    padding: 56px 0;
    border-bottom: 0.5px solid var(--hairline);
  }
  .px-pricing-h {
    font-family: var(--font-sans);
    font-size: clamp(26px, 3vw, 34px);
    font-weight: 500;
    letter-spacing: -0.025em;
    color: var(--ink);
    margin: 0;
  }
  .tier-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 28px;
  }
  .tier-card {
    border-top: 0.5px solid var(--hairline);
    padding: 24px 0;
  }
  .tier-price {
    font-family: var(--font-mono);
    font-size: 28px;
    color: var(--accent);
    margin-bottom: 10px;
  }
  .tier-name {
    font-family: var(--font-sans);
    font-size: 18px;
    font-weight: 500;
    color: var(--ink);
    margin-bottom: 14px;
  }
  .tier-desc {
    font-family: var(--font-serif);
    font-size: 14px;
    line-height: 1.6;
    color: var(--ink-soft);
  }

  /* ========== CONTACT FORM ========== */
  .px-contact {
    padding: 56px 0 96px;
  }
  .contact-form {
    margin-top: 8px;
  }
  .form-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 20px;
    margin-bottom: 16px;
  }
  .form-field {
    display: block;
  }
  .form-field-full {
    margin-bottom: 24px;
  }
  .form-label {
    display: block;
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--ink-soft);
    margin-bottom: 8px;
  }
  .form-input,
  .form-textarea {
    width: 100%;
    font-family: var(--font-serif);
    font-size: 16px;
    padding: 12px 14px;
    border: 0.5px solid var(--hairline-strong);
    background: var(--paper);
    color: var(--ink);
    outline: none;
    transition: border-color 0.15s ease;
  }
  .form-textarea {
    resize: vertical;
    min-height: 120px;
  }
  .form-input:focus,
  .form-textarea:focus { border-color: var(--ink); }
  .form-input::placeholder,
  .form-textarea::placeholder { color: var(--ink-faint); }

  .form-submit {
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    padding: 14px 24px;
    background: var(--ink);
    color: var(--paper);
    border: none;
    cursor: pointer;
    transition: background 0.15s ease;
  }
  .form-submit:hover {
    background: var(--accent);
  }
  .form-note {
    margin-top: 14px;
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--ink-faint);
  }

  /* ========== RESPONSIVE ========== */
  @media (max-width: 900px) {
    .px-hero { padding: 48px 0 40px; }
    .svc-grid,
    .work-grid,
    .tier-grid {
      grid-template-columns: 1fr;
      gap: 24px;
    }
    .proc-row {
      grid-template-columns: 1fr 1fr;
      gap: 24px;
    }
    .form-row { grid-template-columns: 1fr; }
  }
</style>
