---
import BaseLayout from '../layouts/BaseLayout.astro';
import { stories } from '../data/market-watch';
---

<BaseLayout
  title="Market Watch — SpoonAsia"
  description="Quick takes on Thai F&B. News, observations, and short analysis. Faster than Analysis, shorter than a report."
>
  <section class="stories-head">
    <div class="container-narrow">
      <div class="section-tag">▍ Market Watch</div>
      <h1 class="stories-title">Quick takes on Thai F&B</h1>
      <p class="stories-dek">
        <em>
          News, observations, and short analysis.
          Faster than Analysis, shorter than a report.
        </em>
      </p>
    </div>
  </section>

  <section class="stories-list-wrap">
    <div class="container-narrow">
      <ol class="story-list">
        {
          stories.map((s) => (
            <li class="story-item">
              <a href={`/market-watch/${s.slug}`} class="story-link">
                <div class="story-tag">{s.tag}</div>
                <h2 class="story-h">{s.headline}</h2>
                <p class="story-dek-text">{s.dek}</p>
                <div class="story-meta">{s.date}</div>
              </a>
            </li>
          ))
        }
      </ol>
    </div>
  </section>
</BaseLayout>

<style>
  .section-tag {
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--accent);
    margin-bottom: 16px;
  }

  .stories-head {
    padding: 72px 0 40px;
  }
  .stories-title {
    font-family: var(--font-sans);
    font-size: clamp(40px, 5.5vw, 68px);
    font-weight: 500;
    letter-spacing: -0.03em;
    line-height: 1;
    color: var(--ink);
    margin-bottom: 22px;
  }
  .stories-dek {
    font-family: var(--font-serif);
    font-size: clamp(18px, 2vw, 22px);
    line-height: 1.5;
    color: var(--ink-soft);
    max-width: 620px;
  }
  .stories-dek em { font-style: italic; }

  .stories-list-wrap {
    padding: 24px 0 80px;
  }

  .story-list {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .story-item {
    border-top: 0.5px solid var(--hairline);
  }
  .story-item:last-child {
    border-bottom: 0.5px solid var(--hairline);
  }

  .story-link {
    display: block;
    padding: 26px 0;
    text-decoration: none;
    border-bottom: none;
    color: inherit;
    transition: background 0.15s ease;
  }

  .story-tag {
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--accent);
    margin-bottom: 12px;
  }

  .story-h {
    font-family: var(--font-serif);
    font-size: clamp(22px, 2.6vw, 28px);
    font-weight: 500;
    line-height: 1.2;
    letter-spacing: -0.015em;
    color: var(--ink);
    margin: 0 0 10px;
    transition: color 0.15s ease;
  }
  .story-link:hover .story-h { color: var(--accent); }

  .story-dek-text {
    font-family: var(--font-serif);
    font-size: 16px;
    line-height: 1.55;
    color: var(--ink-soft);
    margin-bottom: 14px;
  }

  .story-meta {
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--ink-faint);
  }

  @media (max-width: 900px) {
    .stories-head { padding: 48px 0 32px; }
    .story-link { padding: 22px 0; }
  }
</style>
