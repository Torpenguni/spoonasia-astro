---
import BaseLayout from '../layouts/BaseLayout.astro';

const contacts = [
  { label: 'Editorial', value: 'editorial@spoonasia.com', note: 'Story tips, sources, on/off-the-record requests.' },
  { label: 'Press', value: 'press@spoonasia.com', note: 'Media inquiries, interview requests, conference speaking.' },
  { label: 'Partnerships', value: 'partners@spoonasia.com', note: 'Operator briefings, syndication, Penguin X engagements.' },
  { label: 'General', value: 'hello@spoonasia.com', note: 'Anything else.' },
];

const channels = [
  { label: 'YouTube', href: 'https://youtube.com/@spoonasia', note: 'Video essays and operator walk-throughs.' },
  { label: 'LinkedIn', href: 'https://linkedin.com/company/spoonasia', note: 'Editorial briefs and call-outs.' },
  { label: 'X (Twitter)', href: 'https://x.com/spoonasia', note: 'Real-time market signal.' },
];
---

<BaseLayout
  title="Contact — SpoonAsia"
  description="How to reach the SpoonAsia editorial desk, press team, and partnerships group."
>
  <section class="ct-hero">
    <div class="container-narrow">
      <div class="ct-eyebrow">Contact</div>
      <h1 class="ct-title">Get in touch.</h1>
      <p class="ct-dek">
        We read every message. We answer most within two business days.
        Editorial tips remain confidential. We do not publish source identities without consent.
      </p>
    </div>
  </section>

  <section class="ct-list">
    <div class="container-narrow">
      <div class="ct-section-head">
        <h2 class="section-h">Email</h2>
      </div>

      <ul class="ct-items">
        {
          contacts.map((c) => (
            <li class="ct-item">
              <div class="ct-label">{c.label}</div>
              <a href={`mailto:${c.value}`} class="ct-value">
                {c.value}
              </a>
              <p class="ct-note">{c.note}</p>
            </li>
          ))
        }
      </ul>
    </div>
  </section>

  <section class="ct-channels">
    <div class="container-narrow">
      <div class="ct-section-head">
        <h2 class="section-h">Channels</h2>
      </div>

      <ul class="ct-items">
        {
          channels.map((c) => (
            <li class="ct-item">
              <div class="ct-label">{c.label}</div>
              <a
                href={c.href}
                target="_blank"
                rel="noopener noreferrer"
                class="ct-value"
              >
                {c.href.replace(/^https?:\/\//, '')} ↗
              </a>
              <p class="ct-note">{c.note}</p>
            </li>
          ))
        }
      </ul>
    </div>
  </section>

  <section class="ct-office">
    <div class="container-narrow">
      <div class="ct-section-head">
        <h2 class="section-h">Where we are</h2>
      </div>
      <div class="ct-office-body">
        <p class="ct-office-line">SpoonAsia · A Torpenguin publication</p>
        <p class="ct-office-line">Bangkok, Thailand</p>
        <p class="ct-office-line ct-office-faint">
          We do not maintain a public office address. For mail or service of process, contact <a href="mailto:legal@spoonasia.com">legal@spoonasia.com</a>.
        </p>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .ct-hero {
    padding: 72px 0 48px;
    border-bottom: 0.5px solid var(--hairline);
  }

  .ct-eyebrow {
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--accent);
    margin-bottom: 16px;
  }

  .ct-title {
    font-family: var(--font-sans);
    font-size: clamp(40px, 5vw, 64px);
    font-weight: 800;
    letter-spacing: -0.03em;
    line-height: 1;
    color: var(--ink);
    margin-bottom: 20px;
  }

  .ct-dek {
    font-family: var(--font-serif);
    font-size: clamp(17px, 1.8vw, 20px);
    line-height: 1.55;
    color: var(--ink-soft);
    max-width: 580px;
  }

  .ct-list,
  .ct-channels,
  .ct-office {
    padding: 48px 0;
    border-bottom: 0.5px solid var(--hairline);
  }
  .ct-office { padding-bottom: 80px; }

  .ct-section-head {
    border-top: 2px solid var(--ink);
    padding-top: 16px;
    margin-bottom: 28px;
  }

  .section-h {
    font-family: var(--font-sans);
    font-size: clamp(24px, 3vw, 30px);
    font-weight: 800;
    letter-spacing: -0.02em;
    color: var(--ink);
  }

  .ct-items {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .ct-item {
    padding: 20px 0;
    border-bottom: 0.5px solid var(--hairline);
    display: grid;
    grid-template-columns: 160px 1fr;
    gap: 24px;
    align-items: baseline;
  }
  .ct-item:last-child { border-bottom: none; }

  .ct-label {
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--ink-soft);
  }

  .ct-value {
    font-family: var(--font-sans);
    font-size: 18px;
    font-weight: 600;
    color: var(--ink);
    text-decoration: none;
    border-bottom: 0.5px solid var(--ink-faint);
    transition: color 0.15s ease, border-color 0.15s ease;
    word-break: break-all;
  }
  .ct-value:hover {
    color: var(--accent);
    border-bottom-color: var(--accent);
  }

  .ct-note {
    grid-column: 2;
    margin-top: 6px;
    font-family: var(--font-serif);
    font-size: 14px;
    line-height: 1.55;
    color: var(--ink-faint);
  }

  .ct-office-body {
    padding-top: 8px;
  }

  .ct-office-line {
    font-family: var(--font-serif);
    font-size: 17px;
    line-height: 1.6;
    color: var(--ink);
  }
  .ct-office-faint {
    color: var(--ink-soft);
    margin-top: 12px;
  }
  .ct-office-faint a {
    color: var(--ink);
    border-bottom-color: var(--ink-faint);
  }
  .ct-office-faint a:hover {
    color: var(--accent);
    border-bottom-color: var(--accent);
  }

  @media (max-width: 768px) {
    .ct-item {
      grid-template-columns: 1fr;
      gap: 6px;
    }
    .ct-note { grid-column: 1; }
  }
</style>
